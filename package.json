{
  "name": "wechat-notebank",
  "version": "0.1.0",
  "description": "Archive WeChat public account articles to Markdown with Progressive Summarization",
  "main": "dist/index.js",
  "bin": {
    "wechat-notebank": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
